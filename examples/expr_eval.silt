import float
import int
import list
import math
import option
import result
import string

-- Recursive expression evaluator with simplification, RPN conversion, and complexity analysis.
-- Demonstrates deep pattern matching, or-patterns, and custom Display traits on ADTs.

type Expr {
  Num(Int),
  Add(Expr, Expr),
  Mul(Expr, Expr),
  Neg(Expr),
}

trait Display for Expr {
  fn display(self) -> String {
    match self {
      Num(n) -> "{n}"
      Add(l, r) -> "({l.display()} + {r.display()})"
      Mul(l, r) -> "({l.display()} * {r.display()})"
      Neg(e) -> "(-{e.display()})"
    }
  }
}

-- Evaluate an expression to its integer result
fn eval(expr) {
  match expr {
    Num(n) -> n
    Add(l, r) -> eval(l) + eval(r)
    Mul(l, r) -> eval(l) * eval(r)
    Neg(e) -> -eval(e)
  }
}

-- Algebraic simplification
fn simplify(expr) {
  match expr {
    Num(n) -> Num(n)

    -- Addition simplifications
    Add(l, r) -> {
      let sl = simplify(l)
      let sr = simplify(r)
      match (sl, sr) {
        -- Constant folding
        (Num(a), Num(b)) -> Num(a + b)
        -- x + 0 = x
        (_, Num(0)) -> sl
        -- 0 + x = x
        (Num(0), _) -> sr
        -- x + (-x) patterns using negative literal: e.g. x + Num(-x)
        -- Double negation in add: (-a) + (-b) = -(a + b)
        (Neg(a), Neg(b)) -> simplify(Neg(Add(a, b)))
        _ -> Add(sl, sr)
      }
    }

    -- Multiplication simplifications
    Mul(l, r) -> {
      let sl = simplify(l)
      let sr = simplify(r)
      match (sl, sr) {
        -- Constant folding
        (Num(a), Num(b)) -> Num(a * b)
        -- x * 0 = 0 (or-pattern for both sides)
        (Num(0), _) | (_, Num(0)) -> Num(0)
        -- x * 1 = x
        (_, Num(1)) -> sl
        -- 1 * x = x
        (Num(1), _) -> sr
        -- x * -1 = -x (negative pattern!)
        (x, Num(-1)) -> simplify(Neg(x))
        -- -1 * x = -x (negative pattern!)
        (Num(-1), x) -> simplify(Neg(x))
        -- (-a) * (-b) = a * b
        (Neg(a), Neg(b)) -> simplify(Mul(a, b))
        _ -> Mul(sl, sr)
      }
    }

    -- Negation simplifications
    Neg(e) -> {
      let se = simplify(e)
      match se {
        -- -(-x) = x
        Neg(inner) -> inner
        -- -0 = 0
        Num(0) -> Num(0)
        -- Fold negation of constant (including negative literals)
        Num(n) -> Num(-n)
        _ -> Neg(se)
      }
    }
  }
}

-- Convert expression to Reverse Polish Notation (list of string tokens)
fn to_rpn(expr) {
  match expr {
    Num(n) -> ["{n}"]
    Add(l, r) -> list.concat(list.concat(to_rpn(l), to_rpn(r)), ["+"])
    Mul(l, r) -> list.concat(list.concat(to_rpn(l), to_rpn(r)), ["*"])
    Neg(e) -> list.concat(to_rpn(e), ["neg"])
  }
}

-- Parse an RPN token list back into an Expr
-- Uses front-of-list as stack: head = top, prepend = push, tail = pop
fn from_rpn(tokens) {
  let stack = tokens |> list.fold([]) { stack, token ->
    match token {
      "+" -> {
        let r = list.head(stack) |> option.unwrap_or(Num(0))
        let s1 = list.tail(stack)
        let l = list.head(s1) |> option.unwrap_or(Num(0))
        let s2 = list.tail(s1)
        list.prepend(s2, Add(l, r))
      }
      "*" -> {
        let r = list.head(stack) |> option.unwrap_or(Num(0))
        let s1 = list.tail(stack)
        let l = list.head(s1) |> option.unwrap_or(Num(0))
        let s2 = list.tail(s1)
        list.prepend(s2, Mul(l, r))
      }
      "neg" -> {
        let top = list.head(stack) |> option.unwrap_or(Num(0))
        let rest = list.tail(stack)
        list.prepend(rest, Neg(top))
      }
      numstr -> {
        let n = int.parse(numstr) |> result.unwrap_or(0)
        list.prepend(stack, Num(n))
      }
    }
  }
  list.head(stack) |> option.unwrap_or(Num(0))
}

-- Compute expression depth
fn depth(expr) {
  match expr {
    Num(_) -> 0
    Add(l, r) -> 1 + int.max(depth(l), depth(r))
    Mul(l, r) -> 1 + int.max(depth(l), depth(r))
    Neg(e) -> 1 + depth(e)
  }
}

-- Count total nodes in expression tree
fn node_count(expr) {
  match expr {
    Num(_) -> 1
    Add(l, r) -> 1 + node_count(l) + node_count(r)
    Mul(l, r) -> 1 + node_count(l) + node_count(r)
    Neg(e) -> 1 + node_count(e)
  }
}

-- Classify expression complexity using math.pow for exponential weighting
fn complexity(expr) {
  let d = depth(expr)
  let n = node_count(expr)
  -- Score = nodes * 2^depth, giving exponential weight to deep expressions
  let score = float.to_int(math.pow(2.0, int.to_float(d))) * n
  match {
    d == 0 -> "constant"
    score <= 6 -> "simple"
    score <= 50 -> "compound"
    _ -> "complex"
  }
}

fn main() {
  println("=== Expression Evaluator ===\n")

  -- Build some expressions
  -- (3 + 5) * 2
  let e1 = Mul(Add(Num(3), Num(5)), Num(2))
  -- -(4 + -(2 * 3))
  let e2 = Neg(Add(Num(4), Neg(Mul(Num(2), Num(3)))))
  -- (1 + 0) * (5 + (0 * 99))
  let e3 = Mul(Add(Num(1), Num(0)), Add(Num(5), Mul(Num(0), Num(99))))
  -- Double negation: -(-7)
  let e4 = Neg(Neg(Num(7)))
  -- (-a) * (-b) = a * b: (-3) * (-4)
  let e5 = Mul(Neg(Num(3)), Neg(Num(4)))
  -- Multiply by -1: x * -1 = -x (new: exercises negative patterns)
  let e6 = Mul(Add(Num(2), Num(3)), Num(-1))

  let examples = [
    ("(3+5)*2", e1),
    ("-(4+-(2*3))", e2),
    ("(1+0)*(5+(0*99))", e3),
    ("-(-7)", e4),
    ("(-3)*(-4)", e5),
    ("(2+3)*-1", e6),
  ]

  examples |> list.each { (label, expr) ->
    println("--- {label} ---")
    println("  Pretty:     {expr.display()}")
    println("  Eval:       {eval(expr)}")

    let s = simplify(expr)
    println("  Simplified: {s.display()}")
    println("  Eval(simp): {eval(s)}")

    let rpn = to_rpn(expr)
    let rpn_str = string.join(rpn, " ")
    println("  RPN:        {rpn_str}")

    -- Round-trip: from_rpn(to_rpn(expr)) should equal original
    let roundtrip = from_rpn(rpn)
    println("  Roundtrip:  {roundtrip.display()}")
    println("  RT eval:    {eval(roundtrip)}")

    println("  Complexity: {complexity(expr)}")
    println("  Depth:      {depth(expr)}")
    println("  Nodes:      {node_count(expr)}")
    println("")
  }

  -- Demonstrate deep pattern matching
  println("=== Deep Pattern Matching ===\n")

  let nested = Add(Mul(Num(1), Add(Num(2), Num(3))), Neg(Num(4)))
  println("Expression: {nested.display()}")
  -- Deep match: recognize specific shapes
  let description = match nested {
    Add(Mul(Num(1), inner), _) -> "addition with 1*({inner.display()}) on left"
    Add(_, Neg(Num(n))) -> "addition with -{n} on right"
    _ -> "other"
  }
  println("Deep match result: {description}")

  -- Demonstrate or-patterns in classification
  println("\n=== Or-Pattern Classification ===\n")

  let test_exprs = [
    Num(42),
    Add(Num(1), Num(2)),
    Mul(Num(3), Num(4)),
    Neg(Num(5)),
    Add(Mul(Num(1), Num(2)), Add(Num(3), Num(4))),
    Mul(Add(Mul(Num(1), Num(2)), Num(3)), Add(Num(4), Mul(Num(5), Num(6)))),
  ]

  test_exprs |> list.each { expr ->
    let cls = complexity(expr)
    println("  {expr.display()} -> {cls}")
  }

  -- Build from RPN
  println("\n=== From RPN ===\n")
  let rpn_input = ["3", "4", "+", "2", "*"]
  let rpn_str = string.join(rpn_input, " ")
  let parsed = from_rpn(rpn_input)
  println("  RPN input:  {rpn_str}")
  println("  Parsed:     {parsed.display()}")
  println("  Eval:       {eval(parsed)}")

  -- Demonstrate negative pattern simplification
  println("\n=== Negative Pattern Simplification ===\n")
  let neg_examples = [
    ("5 * -1", Mul(Num(5), Num(-1))),
    ("-1 * 5", Mul(Num(-1), Num(5))),
    ("Neg(Num(-3))", Neg(Num(-3))),
  ]
  neg_examples |> list.each { (label, expr) ->
    let s = simplify(expr)
    println("  {label} -> simplified: {s.display()} = {eval(s)}")
  }

  println("\nDone!")
}
