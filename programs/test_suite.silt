{- Friction Report
   Attempts: 4
   Rating: 8/10
   Highlights: Pattern matching is expressive and natural. Pipe operator with trailing closures
     makes list/string pipelines very readable. try() + test.assert_eq makes building a custom
     test runner trivial. The lack of semicolons and newline-based statement separation
     feels clean once you know the rule. Record update syntax (p.{ x: 10 }) is elegant.
   Friction: The assignment's key pattern example uses semicolons inside match arms and fold
     closures, but silt does not support semicolons — newlines are the statement separator.
     This was confusing on the first attempt. list.tail returns List (not Option), which
     differs from list.head returning Option — slightly inconsistent API that required a
     docs lookup to resolve.
   Missing: Would be nice to have a built-in way to access tuple elements by index (e.g. r.0, r.1)
     without destructuring. A test.assert_match for pattern-based assertions would also be useful.
   Bugs: None encountered — the interpreter behaved correctly in all cases.
-}

-- Test runner infrastructure
fn run_test(name, test_fn) {
  match try(test_fn) {
    Ok(_) -> {
      println("[PASS] {name}")
      (1, 0)
    }
    Err(e) -> {
      println("[FAIL] {name}: {e}")
      (0, 1)
    }
  }
}

-- Arithmetic tests
fn test_arithmetic() {
  test.assert_eq(1 + 1, 2)
  test.assert_eq(10 - 3, 7)
  test.assert_eq(4 * 5, 20)
  test.assert_eq(10 / 2, 5)
  test.assert_eq(10 % 3, 1)
  test.assert(100 > 50)
  test.assert(1 <= 1)
  test.assert_ne(1, 2)
}

-- String tests
fn test_strings() {
  test.assert_eq(string.length("hello"), 5)
  test.assert_eq(string.to_upper("hello"), "HELLO")
  test.assert_eq(string.to_lower("WORLD"), "world")
  test.assert(string.contains("hello world", "world"))
  test.assert_eq(string.replace("foo bar", "bar", "baz"), "foo baz")
  test.assert_eq(string.trim("  hi  "), "hi")
  let parts = string.split("a,b,c", ",")
  test.assert_eq(list.length(parts), 3)
  test.assert_eq(string.join(parts, "-"), "a-b-c")
}

-- String interpolation test
fn test_string_interpolation() {
  let name = "world"
  test.assert_eq("hello {name}", "hello world")
  let x = 42
  test.assert_eq("value is {x}", "value is 42")
}

-- List tests
fn test_lists() {
  let xs = [1, 2, 3, 4, 5]
  test.assert_eq(list.length(xs), 5)
  test.assert_eq(list.head(xs), Some(1))
  test.assert_eq(list.last(xs), Some(5))
  test.assert_eq(list.tail(xs), [2, 3, 4, 5])
  test.assert_eq(list.reverse(xs), [5, 4, 3, 2, 1])
  test.assert(list.contains(xs, 3))
  test.assert_eq(list.head([]), None)
}

-- List higher-order function tests
fn test_list_map_filter_fold() {
  let xs = [1, 2, 3, 4, 5]
  let doubled = xs |> list.map { x -> x * 2 }
  test.assert_eq(doubled, [2, 4, 6, 8, 10])

  let evens = xs |> list.filter { x -> x % 2 == 0 }
  test.assert_eq(evens, [2, 4])

  let total = xs |> list.fold(0) { acc, x -> acc + x }
  test.assert_eq(total, 15)
}

-- Map tests
fn test_maps() {
  let m = #{ "name": "Alice", "age": "30" }
  test.assert_eq(map.get(m, "name"), Some("Alice"))
  test.assert_eq(map.get(m, "missing"), None)
  test.assert_eq(map.length(m), 2)

  let m2 = map.set(m, "city", "NYC")
  test.assert_eq(map.get(m2, "city"), Some("NYC"))
  test.assert_eq(map.length(m2), 3)

  let m3 = map.delete(m2, "age")
  test.assert_eq(map.get(m3, "age"), None)
}

-- Option tests
fn test_option() {
  let s = Some(42)
  let n = None
  test.assert(option.is_some(s))
  test.assert(option.is_none(n))
  test.assert_eq(option.unwrap_or(s, 0), 42)
  test.assert_eq(option.unwrap_or(n, 0), 0)
  let mapped = option.map(s) { x -> x * 2 }
  test.assert_eq(mapped, Some(84))
  test.assert_eq(option.map(n) { x -> x * 2 }, None)
}

-- Result tests
fn test_result() {
  let ok = Ok(10)
  let err = Err("fail")
  test.assert(result.is_ok(ok))
  test.assert(result.is_err(err))
  test.assert_eq(result.unwrap_or(ok, 0), 10)
  test.assert_eq(result.unwrap_or(err, 0), 0)
  let mapped = result.map_ok(ok) { x -> x + 1 }
  test.assert_eq(mapped, Ok(11))
}

-- Record tests
type Point {
  x: Int,
  y: Int,
}

fn test_records() {
  let p = Point { x: 3, y: 4 }
  test.assert_eq(p.x, 3)
  test.assert_eq(p.y, 4)
  let p2 = p.{ x: 10 }
  test.assert_eq(p2.x, 10)
  test.assert_eq(p2.y, 4)
}

-- Pattern matching tests
type Color {
  Red
  Green
  Blue
}

fn color_name(c) {
  match c {
    Red -> "red"
    Green -> "green"
    Blue -> "blue"
  }
}

fn test_patterns() {
  test.assert_eq(color_name(Red), "red")
  test.assert_eq(color_name(Blue), "blue")

  -- Tuple pattern
  let (a, b) = (10, 20)
  test.assert_eq(a, 10)
  test.assert_eq(b, 20)

  -- List pattern
  let [first, ..rest] = [1, 2, 3]
  test.assert_eq(first, 1)
  test.assert_eq(rest, [2, 3])

  -- Guard pattern
  let label = match 42 {
    x when x > 100 -> "big"
    x when x > 10 -> "medium"
    _ -> "small"
  }
  test.assert_eq(label, "medium")
}

-- Pipe operator tests
fn test_pipes() {
  let result = [1, 2, 3, 4, 5]
    |> list.map { x -> x * x }
    |> list.filter { x -> x > 5 }
    |> list.fold(0) { acc, x -> acc + x }
  test.assert_eq(result, 50) -- 9 + 16 + 25

  let words = "hello world foo"
    |> string.split(" ")
    |> list.map { w -> string.to_upper(w) }
    |> string.join(", ")
  test.assert_eq(words, "HELLO, WORLD, FOO")
}

-- Closure tests
fn test_closures() {
  let multiplier = 3
  let mul = fn(x) { x * multiplier }
  test.assert_eq(mul(5), 15)

  -- Closure capturing in list.map
  let offset = 10
  let result = [1, 2, 3] |> list.map { x -> x + offset }
  test.assert_eq(result, [11, 12, 13])
}

-- Loop expression tests
fn test_loops() {
  let total = loop i = 0, acc = 0 {
    match i >= 5 {
      true -> acc
      _ -> loop(i + 1, acc + i)
    }
  }
  test.assert_eq(total, 10) -- 0 + 1 + 2 + 3 + 4

  -- Factorial via loop
  let fact = loop n = 5, acc = 1 {
    match n <= 1 {
      true -> acc
      _ -> loop(n - 1, acc * n)
    }
  }
  test.assert_eq(fact, 120)
}

-- Try/catch tests
fn test_try_catch() {
  let ok_result = try(fn() { 42 })
  test.assert_eq(ok_result, Ok(42))

  let err_result = try(fn() { panic("boom") })
  test.assert(result.is_err(err_result))
}

fn main() {
  println("=== Silt Test Suite ===")
  println("")

  let results = [
    run_test("test_arithmetic", fn() { test_arithmetic() }),
    run_test("test_strings", fn() { test_strings() }),
    run_test("test_string_interpolation", fn() { test_string_interpolation() }),
    run_test("test_lists", fn() { test_lists() }),
    run_test("test_list_map_filter_fold", fn() { test_list_map_filter_fold() }),
    run_test("test_maps", fn() { test_maps() }),
    run_test("test_option", fn() { test_option() }),
    run_test("test_result", fn() { test_result() }),
    run_test("test_records", fn() { test_records() }),
    run_test("test_patterns", fn() { test_patterns() }),
    run_test("test_pipes", fn() { test_pipes() }),
    run_test("test_closures", fn() { test_closures() }),
    run_test("test_loops", fn() { test_loops() }),
    run_test("test_try_catch", fn() { test_try_catch() }),
  ]

  let passed = results |> list.fold(0) { acc, r ->
    let (p, _) = r
    acc + p
  }
  let failed = results |> list.fold(0) { acc, r ->
    let (_, f) = r
    acc + f
  }
  let total = passed + failed

  println("")
  println("=== Results ===")
  println("{passed}/{total} passed, {failed} failed")
  match failed {
    0 -> println("All tests passed!")
    _ -> println("Some tests failed.")
  }
}
