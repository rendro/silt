{- Friction Report
   Attempts: 1
   Rating: 9/10
   Highlights:
     - Recursive ADT definition was clean and natural
     - Or-patterns (Add(l,r) | Mul(l,r)) worked perfectly for tree traversal
     - Pattern matching on nested constructors felt very ergonomic
     - Pipe operator made from_rpn's fold-based stack approach readable
     - String interpolation with method calls ({e.display()}) just worked
     - list.prepend/concat were sufficient for stack manipulation
     - The guardless match (match { cond -> ... }) was a nice if/else replacement
   Friction:
     - Minor: string concatenation via + exists but list.concat for building token
       lists felt slightly verbose compared to a spread/append operator
   Missing:
     - A built-in way to get max/min of a list (only int.max for pairs)
     - No format/to_string for arbitrary values (Display trait helps but requires explicit .display() calls)
   Bugs: None encountered
-}

-- Recursive ADT for arithmetic expressions
type Expr {
  Num(Int)
  Add(Expr, Expr)
  Mul(Expr, Expr)
  Neg(Expr)
}

-- Display trait for pretty-printing expressions
trait Display for Expr {
  fn display(self) -> String {
    match self {
      Num(n) -> "{n}"
      Add(l, r) -> "({l.display()} + {r.display()})"
      Mul(l, r) -> "({l.display()} * {r.display()})"
      Neg(e) -> "(-{e.display()})"
    }
  }
}

-- Evaluate an expression to an integer
fn eval(expr) {
  match expr {
    Num(n) -> n
    Add(l, r) -> eval(l) + eval(r)
    Mul(l, r) -> eval(l) * eval(r)
    Neg(e) -> -eval(e)
  }
}

-- Algebraic simplification
fn simplify(expr) {
  match expr {
    Num(n) -> Num(n)

    -- Simplify children first, then apply rules
    Add(l, r) -> {
      let sl = simplify(l)
      let sr = simplify(r)
      match (sl, sr) {
        -- x + 0 = x
        (e, Num(0)) -> e
        -- 0 + x = x
        (Num(0), e) -> e
        -- constant folding
        (Num(a), Num(b)) -> Num(a + b)
        -- double negation in addition: (-a) + a = 0
        (Neg(a), b) when eval(a) == eval(b) -> Num(0)
        (a, Neg(b)) when eval(a) == eval(b) -> Num(0)
        -- otherwise
        (a, b) -> Add(a, b)
      }
    }

    Mul(l, r) -> {
      let sl = simplify(l)
      let sr = simplify(r)
      match (sl, sr) {
        -- x * 0 = 0 | 0 * x = 0
        (_, Num(0)) | (Num(0), _) -> Num(0)
        -- x * 1 = x
        (e, Num(1)) -> e
        -- 1 * x = x
        (Num(1), e) -> e
        -- constant folding
        (Num(a), Num(b)) -> Num(a * b)
        -- otherwise
        (a, b) -> Mul(a, b)
      }
    }

    Neg(e) -> {
      let se = simplify(e)
      match se {
        -- double negation: -(-x) = x
        Neg(inner) -> inner
        -- negate constant
        Num(n) -> Num(-n)
        -- otherwise
        other -> Neg(other)
      }
    }
  }
}

-- Convert expression to Reverse Polish Notation (list of tokens)
fn to_rpn(expr) {
  match expr {
    Num(n) -> ["{n}"]
    Add(l, r) -> list.concat(list.concat(to_rpn(l), to_rpn(r)), ["+"])
    Mul(l, r) -> list.concat(list.concat(to_rpn(l), to_rpn(r)), ["*"])
    Neg(e) -> list.concat(to_rpn(e), ["neg"])
  }
}

-- Parse an RPN token list back into an Expr
-- Uses a stack-based approach with a loop
fn from_rpn(tokens) {
  let stack = tokens |> list.fold([]) { stack, token ->
    match token {
      "+" -> {
        match stack {
          [b, a, ..rest] -> list.prepend(rest, Add(a, b))
          _ -> panic("invalid RPN: not enough operands for +")
        }
      }
      "*" -> {
        match stack {
          [b, a, ..rest] -> list.prepend(rest, Mul(a, b))
          _ -> panic("invalid RPN: not enough operands for *")
        }
      }
      "neg" -> {
        match stack {
          [top, ..rest] -> list.prepend(rest, Neg(top))
          _ -> panic("invalid RPN: not enough operands for neg")
        }
      }
      numstr -> {
        match int.parse(numstr) {
          Ok(n) -> list.prepend(stack, Num(n))
          Err(e) -> panic("invalid RPN token: {numstr}")
        }
      }
    }
  }
  match stack {
    [result] -> result
    _ -> panic("invalid RPN: leftover stack items")
  }
}

-- Classify expression complexity
fn classify(expr) {
  let depth = tree_depth(expr)
  let ops = count_ops(expr)
  match {
    ops == 0 -> "constant"
    ops == 1 -> "simple"
    ops <= 3 -> "moderate"
    depth <= 3 -> "flat"
    _ -> "complex"
  }
}

fn tree_depth(expr) {
  match expr {
    Num(_) -> 0
    Add(l, r) | Mul(l, r) -> 1 + int.max(tree_depth(l), tree_depth(r))
    Neg(e) -> 1 + tree_depth(e)
  }
}

fn count_ops(expr) {
  match expr {
    Num(_) -> 0
    Add(l, r) | Mul(l, r) -> 1 + count_ops(l) + count_ops(r)
    Neg(e) -> 1 + count_ops(e)
  }
}

fn main() {
  println("=== Expression Evaluator ===")
  println("")

  -- Build: (2 + 3) * (4 + (-1))
  let expr1 = Mul(Add(Num(2), Num(3)), Add(Num(4), Neg(Num(1))))
  println("Expression: {expr1.display()}")
  println("Evaluated:  {eval(expr1)}")
  println("Complexity: {classify(expr1)}")
  println("")

  -- RPN round-trip
  let rpn = to_rpn(expr1)
  let rpn_str = string.join(rpn, " ")
  println("RPN:        {rpn_str}")
  let rebuilt = from_rpn(rpn)
  println("From RPN:   {rebuilt.display()}")
  println("Eval check: {eval(rebuilt)}")
  println("")

  -- Simplification demos
  println("=== Simplification ===")
  println("")

  -- x + 0 = x
  let e2 = Add(Num(5), Num(0))
  println("{e2.display()} => {simplify(e2).display()}")

  -- 0 * x = 0
  let e3 = Mul(Num(0), Add(Num(3), Num(4)))
  println("{e3.display()} => {simplify(e3).display()}")

  -- 1 * x = x
  let e4 = Mul(Num(1), Num(42))
  println("{e4.display()} => {simplify(e4).display()}")

  -- double negation
  let e5 = Neg(Neg(Num(7)))
  println("{e5.display()} => {simplify(e5).display()}")

  -- constant folding
  let e6 = Add(Num(3), Num(4))
  println("{e6.display()} => {simplify(e6).display()}")

  -- Nested: (1 * (2 + 0)) + (0 * 99)
  let e7 = Add(Mul(Num(1), Add(Num(2), Num(0))), Mul(Num(0), Num(99)))
  println("{e7.display()} => {simplify(e7).display()}")
  println("")

  -- Or-pattern demo via classify
  println("=== Classification (or-patterns in tree_depth/count_ops) ===")
  println("")
  let exprs = [
    Num(42),
    Neg(Num(5)),
    Add(Num(1), Num(2)),
    Mul(Add(Num(1), Num(2)), Num(3)),
    expr1
  ]
  exprs |> list.each { e ->
    println("{e.display()} => complexity: {classify(e)}, depth: {tree_depth(e)}, ops: {count_ops(e)}")
  }
}
