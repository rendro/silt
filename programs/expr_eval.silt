{-
  Expression Evaluator in Silt
  ============================

  FRICTION REPORT:

  Rating: 8/10

  WHAT WAS EASY / PLEASANT:
  - Algebraic types with recursive nesting just work out of the box.
  - Pattern matching on nested constructors is natural and readable.
  - String interpolation makes pretty-printing trivial.
  - The pipe operator makes RPN evaluation clean and expressive.
  - Or-patterns for operator matching ("+" | "add" -> ...) are elegant.
  - list.concat replaces the flatten workaround for list building.
  - list.append replaces flatten([[n], stack]) for stack push.
  - Range patterns for complexity classification are concise.
  - Guardless match available for conditional branching (not needed here
    since the pattern matching on ADTs covers all cases naturally).

  REMAINING FRICTION:
  - Cannot define helper functions inside other functions (no local fn).
  - No string indexing makes tokenization harder (not used here).
-}

-- ============================================================
-- Part 1: Algebraic Type Definition (recursive!)
-- ============================================================

type Expr {
  Num(Int)
  Add(Expr, Expr)
  Mul(Expr, Expr)
  Neg(Expr)
}

-- ============================================================
-- Part 2: Display trait for pretty-printing
-- ============================================================

trait Display for Expr {
  fn display(self) -> String {
    match self {
      Num(n) -> "{n}"
      Add(left, right) -> "({left.display()} + {right.display()})"
      Mul(left, right) -> "({left.display()} * {right.display()})"
      Neg(inner) -> "(-{inner.display()})"
    }
  }
}

-- ============================================================
-- Part 3: Recursive Evaluator
-- ============================================================

fn eval_expr(expr) {
  match expr {
    Num(n) -> n
    Add(left, right) -> eval_expr(left) + eval_expr(right)
    Mul(left, right) -> eval_expr(left) * eval_expr(right)
    Neg(inner) -> 0 - eval_expr(inner)
  }
}

-- ============================================================
-- Part 4: Expression Simplifier (deep pattern matching)
-- ============================================================

fn simplify(expr) {
  match expr {
    Add(e, Num(0)) -> simplify(e)
    Add(Num(0), e) -> simplify(e)
    Mul(e, Num(1)) -> simplify(e)
    Mul(Num(1), e) -> simplify(e)
    Mul(_, Num(0)) -> Num(0)
    Mul(Num(0), _) -> Num(0)
    Neg(Neg(inner)) -> simplify(inner)
    Neg(Num(0)) -> Num(0)
    Add(left, right) -> Add(simplify(left), simplify(right))
    Mul(left, right) -> Mul(simplify(left), simplify(right))
    Neg(inner) -> Neg(simplify(inner))
    other -> other
  }
}

-- ============================================================
-- Part 5: RPN (Reverse Polish Notation) Stack Evaluator
-- ============================================================

fn apply_token(stack, token) {
  match token {
    "+" | "add" -> match stack {
      [b, a, ..rest] -> list.concat([a + b], rest)
      _ -> panic("stack underflow on +")
    }
    "*" | "mul" -> match stack {
      [b, a, ..rest] -> list.concat([a * b], rest)
      _ -> panic("stack underflow on *")
    }
    "-" | "sub" -> match stack {
      [b, a, ..rest] -> list.concat([a - b], rest)
      _ -> panic("stack underflow on -")
    }
    "neg" -> match stack {
      [a, ..rest] -> list.concat([0 - a], rest)
      _ -> panic("stack underflow on neg")
    }
    _ -> {
      when Ok(n) = int.parse(token) else {
        return panic("invalid token: {token}")
      }
      list.concat([n], stack)
    }
  }
}

fn eval_rpn(tokens) {
  let result_stack = tokens |> list.fold([]) { stack, tok -> apply_token(stack, tok) }
  match result_stack {
    [answer] -> answer
    [answer, ..rest] -> panic("too many values on stack: {list.length(result_stack)}")
    [] -> panic("empty expression")
  }
}

-- ============================================================
-- Part 6: Expression to RPN converter
-- ============================================================

fn expr_to_rpn(expr) {
  match expr {
    Num(n) -> ["{n}"]
    Add(left, right) -> {
      let l = expr_to_rpn(left)
      let r = expr_to_rpn(right)
      list.concat(list.concat(l, r), ["+"])
    }
    Mul(left, right) -> {
      let l = expr_to_rpn(left)
      let r = expr_to_rpn(right)
      list.concat(list.concat(l, r), ["*"])
    }
    Neg(inner) -> {
      let i = expr_to_rpn(inner)
      list.concat(i, ["neg"])
    }
  }
}

-- ============================================================
-- Part 7: Expression builder helpers
-- ============================================================

fn num(n) = Num(n)
fn add(a, b) = Add(a, b)
fn mul(a, b) = Mul(a, b)
fn neg(a) = Neg(a)

-- ============================================================
-- Part 8: Classify expression complexity using range patterns
-- ============================================================

fn count_nodes(expr) {
  match expr {
    Num(_) -> 1
    Add(l, r) -> 1 + count_nodes(l) + count_nodes(r)
    Mul(l, r) -> 1 + count_nodes(l) + count_nodes(r)
    Neg(inner) -> 1 + count_nodes(inner)
  }
}

fn classify_complexity(expr) {
  let n = count_nodes(expr)
  match n {
    1 -> "trivial (just a number)"
    2..3 -> "simple"
    4..7 -> "moderate"
    8..15 -> "complex"
    _ -> "very complex ({n} nodes)"
  }
}

-- ============================================================
-- Part 9: Expression depth calculator
-- ============================================================

fn depth(expr) {
  match expr {
    Num(_) -> 0
    Add(l, r) -> 1 + int.max(depth(l), depth(r))
    Mul(l, r) -> 1 + int.max(depth(l), depth(r))
    Neg(inner) -> 1 + depth(inner)
  }
}

-- ============================================================
-- Main: test everything
-- ============================================================

fn main() {
  println("=== Silt Expression Evaluator ===")
  println("")

  -- Test 1: Basic construction and evaluation
  println("--- Test 1: Basic expressions ---")
  let e1 = Num(42)
  let e2 = Add(Num(3), Num(4))
  let e3 = Mul(Num(5), Num(6))
  let e4 = Neg(Num(7))

  println("  {e1.display()} = {eval_expr(e1)}")
  println("  {e2.display()} = {eval_expr(e2)}")
  println("  {e3.display()} = {eval_expr(e3)}")
  println("  {e4.display()} = {eval_expr(e4)}")
  println("")

  -- Test 2: Nested / complex expressions
  println("--- Test 2: Nested expressions ---")
  let e5 = Mul(Add(Num(3), Num(4)), Num(2))
  let e6 = Neg(Mul(Num(5), Add(Num(2), Num(3))))
  let e7 = Add(Add(Num(1), Num(2)), Add(Num(3), Num(4)))

  println("  {e5.display()} = {eval_expr(e5)}")
  println("  {e6.display()} = {eval_expr(e6)}")
  println("  {e7.display()} = {eval_expr(e7)}")
  println("")

  -- Test 3: Simplification (deep pattern matching)
  println("--- Test 3: Simplification ---")
  let s1 = Add(Num(5), Num(0))
  let s2 = Mul(Num(1), Add(Num(3), Num(4)))
  let s3 = Mul(Num(0), Add(Num(99), Num(100)))
  let s4 = Neg(Neg(Num(42)))

  println("  {s1.display()} simplifies to {simplify(s1).display()}")
  println("  {s2.display()} simplifies to {simplify(s2).display()}")
  println("  {s3.display()} simplifies to {simplify(s3).display()}")
  println("  {s4.display()} simplifies to {simplify(s4).display()}")
  println("")

  -- Test 4: RPN evaluation (stack-based, or-patterns)
  println("--- Test 4: RPN evaluation ---")
  let rpn1 = ["3", "4", "+"]
  let rpn2 = ["3", "4", "add", "2", "mul"]
  let rpn3 = ["5", "2", "3", "+", "*"]
  let rpn4 = ["10", "3", "sub"]
  let rpn5 = ["7", "neg"]

  println("  [3, 4, +] = {eval_rpn(rpn1)}")
  println("  [3, 4, add, 2, mul] = {eval_rpn(rpn2)}")
  println("  [5, 2, 3, +, *] = {eval_rpn(rpn3)}")
  println("  [10, 3, sub] = {eval_rpn(rpn4)}")
  println("  [7, neg] = {eval_rpn(rpn5)}")
  println("")

  -- Test 5: AST to RPN conversion round-trip
  println("--- Test 5: AST -> RPN -> eval round-trip ---")
  let complex = Mul(Add(Num(3), Num(4)), Add(Num(1), Num(2)))
  let rpn_tokens = expr_to_rpn(complex)
  let rpn_str = string.join(rpn_tokens, " ")
  let direct = eval_expr(complex)
  let via_rpn = eval_rpn(rpn_tokens)

  println("  Expression: {complex.display()}")
  println("  RPN tokens: {rpn_str}")
  println("  Direct eval: {direct}")
  println("  Via RPN:     {via_rpn}")
  println("  Match: {direct == via_rpn}")
  println("")

  -- Test 6: Complexity classification (range patterns)
  println("--- Test 6: Complexity classification ---")
  let exprs = [
    Num(1),
    Add(Num(1), Num(2)),
    Mul(Add(Num(1), Num(2)), Num(3)),
    Mul(Add(Num(1), Num(2)), Add(Num(3), Num(4))),
    Add(Mul(Add(Num(1), Num(2)), Num(3)), Mul(Num(4), Add(Num(5), Num(6))))
  ]

  exprs |> list.each { e ->
    let nodes = count_nodes(e)
    let d = depth(e)
    println("  {e.display()} -> {classify_complexity(e)}, depth={d}, nodes={nodes}")
  }
  println("")

  -- Test 7: Verify simplifier preserves semantics
  println("--- Test 7: Simplifier correctness ---")
  let test_cases = [
    Add(Num(5), Num(0)),
    Add(Num(0), Num(5)),
    Mul(Num(3), Num(1)),
    Mul(Num(1), Num(3)),
    Mul(Num(99), Num(0)),
    Mul(Num(0), Num(99)),
    Neg(Neg(Num(42))),
    Neg(Num(0)),
    Add(Mul(Num(1), Num(5)), Mul(Num(3), Num(0)))
  ]

  test_cases |> list.each { e ->
    let original = eval_expr(e)
    let simplified = simplify(e)
    let after = eval_expr(simplified)
    let ok = match original == after {
      true -> "OK"
      false -> "MISMATCH!"
    }
    println("  {e.display()} = {original}, simplified: {simplified.display()} = {after} [{ok}]")
  }

  println("")
  println("=== All tests complete ===")
}
