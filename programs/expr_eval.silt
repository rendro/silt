{- Friction Report
   Attempts: 2
   Rating: 9/10
   Highlights: Recursive ADTs with pattern matching are excellent. Deep pattern matching
     on nested constructors like Add(Mul(Num(a), Num(b)), Neg(Num(c))) just works.
     Or-patterns with shared bindings (Add(l, r) | Mul(l, r) -> ...) are very ergonomic
     for writing tree-walking functions. Trait Display for ADTs is clean. String
     interpolation with method calls ({e.display()}) is pleasant. Pipe operator
     with trailing closures makes list processing readable.
   Friction: The language summary says "Semicolons separate expressions in blocks"
     but the actual parser rejects semicolons with a helpful error message suggesting
     newlines instead. This was the only issue encountered. The error message was
     clear enough to fix immediately.
   Missing: No unary negation operator (had to use 0 - x). A negate function or
     unary minus would be convenient. No built-in way to convert ADT values to
     strings without implementing Display manually (though the trait system makes
     this straightforward).
   Bugs: None encountered.
-}

-- Recursive ADT for arithmetic expressions
type Expr {
  Num(Int)
  Add(Expr, Expr)
  Mul(Expr, Expr)
  Neg(Expr)
}

-- Display trait for pretty-printing expressions
trait Display for Expr {
  fn display(self) -> String {
    match self {
      Num(n) -> int.to_string(n)
      Add(left, right) -> "({left.display()} + {right.display()})"
      Mul(left, right) -> "({left.display()} * {right.display()})"
      Neg(inner) -> "(-{inner.display()})"
    }
  }
}

-- Evaluate an expression to an integer
fn eval(expr) {
  match expr {
    Num(n) -> n
    Add(left, right) -> eval(left) + eval(right)
    Mul(left, right) -> eval(left) * eval(right)
    Neg(inner) -> 0 - eval(inner)
  }
}

-- Algebraic simplification
fn simplify(expr) {
  match expr {
    Num(n) -> Num(n)

    -- Simplify children first, then apply rules
    Add(left, right) -> {
      let sl = simplify(left)
      let sr = simplify(right)
      match (sl, sr) {
        -- x + 0 = x, 0 + x = x
        (e, Num(0)) -> e
        (Num(0), e) -> e
        -- constant folding
        (Num(a), Num(b)) -> Num(a + b)
        -- default
        (a, b) -> Add(a, b)
      }
    }

    Mul(left, right) -> {
      let sl = simplify(left)
      let sr = simplify(right)
      match (sl, sr) {
        -- x * 0 = 0, 0 * x = 0
        (_, Num(0)) | (Num(0), _) -> Num(0)
        -- x * 1 = x, 1 * x = x
        (e, Num(1)) -> e
        (Num(1), e) -> e
        -- constant folding
        (Num(a), Num(b)) -> Num(a * b)
        -- default
        (a, b) -> Mul(a, b)
      }
    }

    Neg(inner) -> {
      let si = simplify(inner)
      match si {
        -- double negation: --x = x
        Neg(e) -> e
        -- negate constant
        Num(n) -> Num(0 - n)
        -- default
        e -> Neg(e)
      }
    }
  }
}

-- Convert expression to Reverse Polish Notation (list of string tokens)
fn to_rpn(expr) {
  match expr {
    Num(n) -> [int.to_string(n)]
    Add(left, right) -> list.concat(list.concat(to_rpn(left), to_rpn(right)), ["+"])
    Mul(left, right) -> list.concat(list.concat(to_rpn(left), to_rpn(right)), ["*"])
    Neg(inner) -> list.concat(to_rpn(inner), ["neg"])
  }
}

-- Parse an expression from RPN tokens
-- Uses a stack-based approach: returns Ok(Expr) or Err(String)
fn from_rpn(tokens) {
  let result = list.fold(tokens, Ok([])) { acc, token ->
    match acc {
      Err(e) -> Err(e)
      Ok(stack) -> match token {
        "+" -> match stack {
          [b, a, ..rest] -> Ok(list.prepend(rest, Add(a, b)))
          _ -> Err("not enough operands for +")
        }
        "*" -> match stack {
          [b, a, ..rest] -> Ok(list.prepend(rest, Mul(a, b)))
          _ -> Err("not enough operands for *")
        }
        "neg" -> match stack {
          [top, ..rest] -> Ok(list.prepend(rest, Neg(top)))
          _ -> Err("not enough operands for neg")
        }
        _ -> match int.parse(token) {
          Ok(n) -> Ok(list.prepend(stack, Num(n)))
          Err(e) -> Err("invalid token: {token}")
        }
      }
    }
  }
  match result {
    Err(e) -> Err(e)
    Ok([expr]) -> Ok(expr)
    Ok(_) -> Err("invalid RPN: leftover items on stack")
  }
}

-- Classify expression complexity
fn classify(expr) {
  match expr {
    Num(_) -> "constant"
    Neg(Num(_)) -> "constant"
    Add(Num(_), Num(_)) | Mul(Num(_), Num(_)) -> "simple"
    Add(_, _) | Mul(_, _) -> "compound"
    Neg(inner) -> classify(inner)
  }
}

-- Count the depth of an expression tree
fn depth(expr) {
  match expr {
    Num(_) -> 0
    Add(left, right) | Mul(left, right) -> 1 + int.max(depth(left), depth(right))
    Neg(inner) -> 1 + depth(inner)
  }
}

-- Count the number of nodes
fn node_count(expr) {
  match expr {
    Num(_) -> 1
    Add(left, right) | Mul(left, right) -> 1 + node_count(left) + node_count(right)
    Neg(inner) -> 1 + node_count(inner)
  }
}

fn main() {
  println("=== Expression Evaluator ===")
  println("")

  -- Build some expressions
  -- (3 + 5) * 2
  let e1 = Mul(Add(Num(3), Num(5)), Num(2))
  -- -(4 + 0)
  let e2 = Neg(Add(Num(4), Num(0)))
  -- (1 * x) where x = (2 + 3), should simplify
  let e3 = Mul(Num(1), Add(Num(2), Num(3)))
  -- double negation: -(-7)
  let e4 = Neg(Neg(Num(7)))
  -- 0 * (complex expression)
  let e5 = Mul(Num(0), Add(Mul(Num(3), Num(4)), Num(5)))

  let exprs = [e1, e2, e3, e4, e5]

  -- Evaluate and display each expression
  println("-- Evaluation --")
  exprs |> list.each { e ->
    println("  {e.display()} = {eval(e)}")
  }

  -- Simplify each expression
  println("")
  println("-- Simplification --")
  exprs |> list.each { e ->
    let s = simplify(e)
    println("  {e.display()} => {s.display()} = {eval(s)}")
  }

  -- Convert to RPN and back
  println("")
  println("-- RPN Round-trip --")
  exprs |> list.each { e ->
    let rpn = to_rpn(e)
    let rpn_str = string.join(rpn, " ")
    let rebuilt = from_rpn(rpn)
    match rebuilt {
      Ok(re) -> println("  {e.display()} -> RPN: {rpn_str} -> rebuilt: {re.display()} = {eval(re)}")
      Err(msg) -> println("  {e.display()} -> RPN: {rpn_str} -> ERROR: {msg}")
    }
  }

  -- Classify complexity
  println("")
  println("-- Classification --")
  exprs |> list.each { e ->
    println("  {e.display()} : {classify(e)}")
  }

  -- Show depth and node count using or-patterns
  println("")
  println("-- Tree Stats --")
  exprs |> list.each { e ->
    println("  {e.display()} : depth={depth(e)}, nodes={node_count(e)}")
  }

  -- Demonstrate deep pattern matching
  println("")
  println("-- Deep Pattern Matching --")
  let deep_expr = Add(Mul(Num(2), Num(3)), Neg(Num(4)))
  match deep_expr {
    Add(Mul(Num(a), Num(b)), Neg(Num(c))) ->
      println("  Matched: ({a} * {b}) + (-{c}) = {a * b - c}")
    _ -> println("  no match")
  }

  -- Demonstrate or-patterns
  println("")
  println("-- Or-Pattern Matching --")
  let test_exprs = [Num(5), Add(Num(1), Num(2)), Mul(Num(3), Num(4)), Neg(Num(6))]
  test_exprs |> list.each { e ->
    let kind = match e {
      Add(_, _) | Mul(_, _) -> "binary operation"
      Neg(_) -> "unary operation"
      Num(_) -> "literal"
    }
    println("  {e.display()} is a {kind}")
  }

  println("")
  println("Done!")
}
