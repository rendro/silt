{- Friction Report
   Attempts: 1 (worked on first run)
   Rating: 9/10 (very natural for this kind of program)
   Highlights:
     - Recursive ADT definition is clean and concise
     - Or-patterns (Add(l, r) | Mul(l, r)) work beautifully for shared logic across variants
     - Pattern matching on nested constructors is powerful and readable
     - Pipe operator + trailing closures make list processing elegant
     - Display trait implementation is straightforward
     - list.fold with pattern matching on the accumulator made the RPN stack parser natural
     - Guardless match and when guards provide flexible branching
   Friction:
     - No way to derive Display automatically; manual impl required even for simple types
     - String interpolation requires .display() call for custom types rather than auto-calling it
   Missing:
     - No list.push / stack-oriented operations (used list.prepend as workaround, which works well)
     - No exponentiation operator (not needed here, but would be natural for an expression evaluator)
   Bugs: None encountered
-}

-- Recursive ADT for arithmetic expressions
type Expr {
  Num(Int)
  Add(Expr, Expr)
  Mul(Expr, Expr)
  Neg(Expr)
}

-- Display trait for pretty-printing expressions
trait Display for Expr {
  fn display(self) -> String {
    match self {
      Num(n) -> "{n}"
      Add(l, r) -> "({l.display()} + {r.display()})"
      Mul(l, r) -> "({l.display()} * {r.display()})"
      Neg(e) -> "(-{e.display()})"
    }
  }
}

-- Evaluate an expression to its integer result
fn eval(expr) {
  match expr {
    Num(n) -> n
    Add(l, r) -> eval(l) + eval(r)
    Mul(l, r) -> eval(l) * eval(r)
    Neg(e) -> -eval(e)
  }
}

-- Algebraic simplification
-- Rules:
--   Add(Num(0), x) | Add(x, Num(0)) -> x
--   Mul(Num(0), _) | Mul(_, Num(0)) -> Num(0)
--   Mul(Num(1), x) | Mul(x, Num(1)) -> x
--   Neg(Neg(x)) -> x
--   Neg(Num(0)) -> Num(0)
--   Constant folding for fully numeric subexpressions
fn simplify(expr) {
  -- First simplify children, then apply rules to the result
  let simplified = match expr {
    Num(n) -> Num(n)
    Add(l, r) -> {
      let sl = simplify(l)
      let sr = simplify(r)
      match (sl, sr) {
        -- Constant folding
        (Num(a), Num(b)) -> Num(a + b)
        -- Identity: 0 + x = x
        (Num(0), x) -> x
        -- Identity: x + 0 = x
        (x, Num(0)) -> x
        _ -> Add(sl, sr)
      }
    }
    Mul(l, r) -> {
      let sl = simplify(l)
      let sr = simplify(r)
      match (sl, sr) {
        -- Constant folding
        (Num(a), Num(b)) -> Num(a * b)
        -- Zero: 0 * x = 0
        (Num(0), _) -> Num(0)
        -- Zero: x * 0 = 0
        (_, Num(0)) -> Num(0)
        -- Identity: 1 * x = x
        (Num(1), x) -> x
        -- Identity: x * 1 = x
        (x, Num(1)) -> x
        _ -> Mul(sl, sr)
      }
    }
    Neg(e) -> {
      let se = simplify(e)
      match se {
        -- Double negation
        Neg(inner) -> inner
        -- Neg of zero
        Num(0) -> Num(0)
        -- Constant folding
        Num(n) -> Num(-n)
        _ -> Neg(se)
      }
    }
  }
  simplified
}

-- Convert expression to Reverse Polish Notation (list of tokens)
fn to_rpn(expr) {
  match expr {
    Num(n) -> ["{n}"]
    Add(l, r) -> list.concat(list.concat(to_rpn(l), to_rpn(r)), ["+"])
    Mul(l, r) -> list.concat(list.concat(to_rpn(l), to_rpn(r)), ["*"])
    Neg(e) -> list.concat(to_rpn(e), ["neg"])
  }
}

-- Parse from RPN token list back to an Expr
-- Uses a stack-based approach with loop
fn from_rpn(tokens) {
  let stack = tokens |> list.fold([]) { stack, token ->
    match token {
      "+" -> {
        -- Pop two operands
        match stack {
          [b, a, ..rest] -> list.prepend(rest, Add(a, b))
          _ -> panic("invalid RPN: not enough operands for +")
        }
      }
      "*" -> {
        match stack {
          [b, a, ..rest] -> list.prepend(rest, Mul(a, b))
          _ -> panic("invalid RPN: not enough operands for *")
        }
      }
      "neg" -> {
        match stack {
          [a, ..rest] -> list.prepend(rest, Neg(a))
          _ -> panic("invalid RPN: not enough operands for neg")
        }
      }
      _ -> {
        -- Must be a number
        match int.parse(token) {
          Ok(n) -> list.prepend(stack, Num(n))
          Err(e) -> panic("invalid RPN token: {token}")
        }
      }
    }
  }
  -- Stack should have exactly one element
  match stack {
    [result] -> result
    _ -> panic("invalid RPN: expected single result on stack")
  }
}

-- Classify expression complexity
-- "constant" - just a number
-- "linear" - additions/negations only (no multiplication)
-- "polynomial" - contains multiplication
fn classify(expr) {
  match expr {
    Num(_) -> "constant"
    Add(l, r) -> {
      let cl = classify(l)
      let cr = classify(r)
      match (cl, cr) {
        _ when cl == "polynomial" -> "polynomial"
        _ when cr == "polynomial" -> "polynomial"
        _ -> "linear"
      }
    }
    Mul(_, _) -> "polynomial"
    Neg(e) -> {
      match classify(e) {
        "polynomial" -> "polynomial"
        "constant" -> "constant"
        _ -> "linear"
      }
    }
  }
}

-- Count the number of nodes in an expression tree
fn node_count(expr) {
  match expr {
    Num(_) -> 1
    Add(l, r) | Mul(l, r) -> 1 + node_count(l) + node_count(r)
    Neg(e) -> 1 + node_count(e)
  }
}

-- Check if an expression contains any negation
fn has_negation(expr) {
  match expr {
    Num(_) -> false
    Add(l, r) | Mul(l, r) -> has_negation(l) || has_negation(r)
    Neg(_) -> true
  }
}

-- Depth of the expression tree
fn depth(expr) {
  match expr {
    Num(_) -> 0
    Add(l, r) | Mul(l, r) -> 1 + int.max(depth(l), depth(r))
    Neg(e) -> 1 + depth(e)
  }
}

fn main() {
  println("=== Expression Evaluator ===")
  println("")

  -- Build some test expressions
  -- (3 + 5) * 2
  let e1 = Mul(Add(Num(3), Num(5)), Num(2))
  println("Expression: {e1.display()}")
  println("Evaluated:  {eval(e1)}")
  println("Complexity: {classify(e1)}")
  println("Nodes:      {node_count(e1)}")
  println("Depth:      {depth(e1)}")
  println("")

  -- -(4 + (-3))
  let e2 = Neg(Add(Num(4), Neg(Num(3))))
  println("Expression: {e2.display()}")
  println("Evaluated:  {eval(e2)}")
  println("Complexity: {classify(e2)}")
  println("Has neg:    {has_negation(e2)}")
  println("")

  -- Simplification demos
  println("=== Simplification ===")
  println("")

  -- x + 0 -> x
  let e3 = Add(Num(7), Num(0))
  println("Before: {e3.display()}")
  let s3 = simplify(e3)
  println("After:  {s3.display()}")
  println("")

  -- 0 * x -> 0
  let e4 = Mul(Num(0), Add(Num(3), Num(5)))
  println("Before: {e4.display()}")
  let s4 = simplify(e4)
  println("After:  {s4.display()}")
  println("")

  -- 1 * x -> x
  let e5 = Mul(Num(1), Add(Num(2), Num(3)))
  println("Before: {e5.display()}")
  let s5 = simplify(e5)
  println("After:  {s5.display()}")
  println("")

  -- Double negation: --x -> x
  let e6 = Neg(Neg(Num(42)))
  println("Before: {e6.display()}")
  let s6 = simplify(e6)
  println("After:  {s6.display()}")
  println("")

  -- Constant folding: (3 + 5) * (2 + 1) -> 24
  let e7 = Mul(Add(Num(3), Num(5)), Add(Num(2), Num(1)))
  println("Before: {e7.display()}")
  let s7 = simplify(e7)
  println("After:  {s7.display()}")
  println("")

  -- RPN conversion
  println("=== Reverse Polish Notation ===")
  println("")

  let e8 = Add(Mul(Num(3), Num(4)), Num(5))
  println("Expression: {e8.display()}")
  let rpn = to_rpn(e8)
  println("RPN:        {string.join(rpn, " ")}")
  println("")

  -- Round-trip: expression -> RPN -> expression -> eval
  let e9 = Mul(Add(Num(2), Num(3)), Neg(Num(4)))
  println("Original:   {e9.display()} = {eval(e9)}")
  let rpn9 = to_rpn(e9)
  println("RPN:        {string.join(rpn9, " ")}")
  let rebuilt = from_rpn(rpn9)
  println("Rebuilt:    {rebuilt.display()} = {eval(rebuilt)}")
  println("")

  -- More complex expression for classification
  println("=== Classification ===")
  println("")
  let exprs = [
    Num(42),
    Add(Num(1), Num(2)),
    Neg(Num(5)),
    Mul(Num(3), Num(4)),
    Add(Num(1), Mul(Num(2), Num(3))),
    Neg(Add(Num(1), Num(2))),
  ]
  exprs |> list.each { e ->
    println("{e.display()} -> {classify(e)} (nodes: {node_count(e)}, depth: {depth(e)})")
  }
  println("")

  -- Demonstrate deep pattern matching with or-patterns
  println("=== Deep Pattern Matching ===")
  println("")
  let test_exprs = [
    Num(0),
    Num(1),
    Add(Num(0), Num(5)),
    Mul(Num(1), Num(7)),
    Neg(Neg(Num(3))),
    Add(Mul(Num(2), Num(3)), Num(1)),
  ]
  test_exprs |> list.each { e ->
    let desc = match e {
      Num(0) | Num(1) -> "special constant"
      Num(n) -> "constant {n}"
      Add(Num(0), x) | Add(x, Num(0)) -> "identity addition: {x.display()}"
      Mul(Num(1), x) | Mul(x, Num(1)) -> "identity multiplication: {x.display()}"
      Neg(Neg(inner)) -> "double negation of {inner.display()}"
      Add(Mul(_, _), _) | Add(_, Mul(_, _)) -> "mixed add/mul"
      _ -> "other: {e.display()}"
    }
    println("  {e.display()} => {desc}")
  }
}
