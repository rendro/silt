  |> list.filter { l -> !string.is_empty(l) }
  |> list.map { line -> regex.split("\\s+", line)
  |> list.filter { w -> !string.is_empty(w) }
  |> list.length }
  |> list.fold(0) { acc, n -> acc + n }
}

fn extract_field(content, field_name) {
  let lines = content
  |> string.split("\n")
  let found = lines
  |> list.find { l -> string.starts_with(l, field_name) }
  match found {
    Some(line) -> {
      let parts = line
      |> string.split(": ")
      match list.get(parts, 1) {
        Some(val) -> string.trim(val)
        None -> "N/A"
      }
    }
    None -> "N/A"
  }
}

fn worker(id, jobs, results) {
  channel.each(jobs) { path ->
    let outcome = match io.read_file(path) {
      Ok(content) -> {
        let lines = count_lines(content)
        let words = count_words(content)
        let dept = extract_field(content, "Department")
        let revenue = extract_field(content, "Revenue")
        Ok((path, lines, words, dept, revenue))
      }
      Err(e) -> Err((path, e))
    }
    channel.send(results, (id, outcome))
  }
}

