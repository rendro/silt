-- Parallel file processor using channels and tasks.
-- Spawns worker tasks that read files, extract stats, and send results
-- back through channels for aggregation.

fn count_lines(content) {
  content
  |> string.split("\n")
  |> list.filter { l -> !string.is_empty(l) }
  |> list.length
}

